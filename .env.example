# Example environment variables for MiniPasswordVault
# Start a local MySQL (see README or use provided docker command)
# Replace username/password/host/db as needed
DATABASE_URL=mysql://root:example@127.0.0.1:3306/vault
FLASK_SECRET_KEY=change-me-to-a-secure-secret
# Optional: enable debug (not recommended in production)
#FLASK_ENV=development
